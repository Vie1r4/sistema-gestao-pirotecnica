@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<h1 class="text-danger">Ocorreu um erro</h1>
<h2 class="text-danger">Não foi possível processar o seu pedido.</h2>

<p class="mt-3">
    Tente novamente mais tarde. Se o problema persistir, contacte o suporte.
</p>

@if (Model.ShowRequestId)
{
    <p class="mt-3 small text-muted">
        <strong>ID do pedido:</strong> <code>@Model.RequestId</code>
        <br />
        <span class="fst-italic">Pode fornecer este identificador ao suporte para facilitar o diagnóstico.</span>
    </p>
}

@model IEnumerable<Finalproj.Models.Encomenda>
@using Finalproj.Models
@{
    ViewData["Title"] = "Encomendas";
    var estado = ViewData["Estado"] as string ?? "";
    var estados = ViewData["EstadosParaFiltro"] as string[] ?? ConstantesEncomenda.TodosEstados;
    var lista = Model.ToList();
    var totaisPorEstado = ViewData["TotaisPorEstado"] as Dictionary<string, int> ?? new Dictionary<string, int>();
    var totalGeral = (int)(ViewData["TotalGeral"] ?? 0);
    var pendentes = totaisPorEstado.GetValueOrDefault(ConstantesEncomenda.PENDENTE, 0);
    var paginaAtual = (int)(ViewData["PaginaAtual"] ?? 1);
    var totalRegistos = (int)(ViewData["TotalRegistos"] ?? 0);
    var itensPorPagina = (int)(ViewData["ItensPorPagina"] ?? 20);
    var totalPaginas = itensPorPagina > 0 ? (int)Math.Ceiling(totalRegistos / (double)itensPorPagina) : 1;
    var nomesEstados = new Dictionary<string, string>
    {
        [ConstantesEncomenda.PENDENTE] = "Pendentes",
        [ConstantesEncomenda.ACEITE] = "Aceites",
        [ConstantesEncomenda.REJEITADA] = "Rejeitadas",
        [ConstantesEncomenda.EM_PREPARACAO] = "Em preparação",
        [ConstantesEncomenda.CONCLUIDA] = "Concluídas"
    };
}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Encomendas</h1>
        <p class="text-muted mb-0">Consulte e gere encomendas. Fluxo: Pendente → Aceite ou Rejeitada; Aceite → Em preparação → Concluída.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Nova encomenda</a>
    }
</div>

@if (User.IsInRole("Admin") && pendentes > 0)
{
    <div class="alert alert-warning border-0 shadow-sm d-flex flex-wrap align-items-center gap-2 mb-4">
        <span>Há <strong>@pendentes</strong> encomenda(s) pendente(s) de aceitação.</span>
        <a asp-action="Index" asp-route-estado="@ConstantesEncomenda.PENDENTE" class="btn btn-sm btn-warning text-dark ms-auto">Ver pendentes</a>
    </div>
}

<div class="d-flex flex-wrap align-items-center gap-3 mb-4">
    <label class="form-label text-muted small mb-0">Estado:</label>
    <select class="form-select form-select-sm" style="width: auto; min-width: 180px;" onchange="window.location.href = this.value">
        @if (string.IsNullOrEmpty(estado))
        {
            <option value="@Url.Action("Index", new { pagina = 1 })" selected>Todos (@totalGeral)</option>
        }
        else
        {
            <option value="@Url.Action("Index", new { pagina = 1 })">Todos (@totalGeral)</option>
        }
        @foreach (var e in estados)
        {
            var countEstado = totaisPorEstado.GetValueOrDefault(e, 0);
            var label = nomesEstados.GetValueOrDefault(e, e);
            if (estado == e)
            {
                <option value="@Url.Action("Index", new { estado = e, pagina = 1 })" selected>@label (@countEstado)</option>
            }
            else
            {
                <option value="@Url.Action("Index", new { estado = e, pagina = 1 })">@label (@countEstado)</option>
            }
        }
    </select>
</div>

@if (lista.Any())
{
    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width: 80px;">N.º</th>
                        <th>Cliente</th>
                        <th style="width: 130px;">Estado</th>
                        <th style="width: 110px;">Data entrega</th>
                        <th style="width: 115px;">Criação</th>
                        <th class="text-end pe-4" style="width: 100px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in lista)
                    {
                        var badgeClass = item.Estado switch
                        {
                            ConstantesEncomenda.PENDENTE => "bg-warning text-dark",
                            ConstantesEncomenda.ACEITE => "bg-info",
                            ConstantesEncomenda.REJEITADA => "bg-danger",
                            ConstantesEncomenda.EM_PREPARACAO => "bg-primary",
                            ConstantesEncomenda.CONCLUIDA => "bg-success",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td class="ps-4"><strong>#@item.Id</strong></td>
                            <td>@item.Cliente?.Nome</td>
                            <td><span class="badge rounded-pill @badgeClass">@item.Estado</span></td>
                            <td class="text-muted small">@(item.DataEntrega.HasValue ? item.DataEntrega.Value.ToString("dd/MM/yyyy") : "—")</td>
                            <td class="text-muted small">@item.DataCriacao.ToString("dd/MM/yy HH:mm")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Detalhes</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (totalPaginas > 1)
    {
        <nav class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
            <p class="text-muted small mb-0">A mostrar @((paginaAtual - 1) * itensPorPagina + 1)–@(Math.Min(paginaAtual * itensPorPagina, totalRegistos)) de @totalRegistos</p>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(paginaAtual <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@(paginaAtual <= 1 ? "#" : Url.Action("Index", new { estado = string.IsNullOrEmpty(estado) ? null : estado, pagina = paginaAtual - 1, itensPorPagina }))">Anterior</a>
                </li>
                @for (var p = 1; p <= Math.Min(totalPaginas, 10); p++)
                {
                    var pg = p;
                    <li class="page-item @(pg == paginaAtual ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { estado = string.IsNullOrEmpty(estado) ? null : estado, pagina = pg, itensPorPagina })">@pg</a>
                    </li>
                }
                @if (totalPaginas > 10)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                    <li class="page-item"><a class="page-link" href="@Url.Action("Index", new { estado = string.IsNullOrEmpty(estado) ? null : estado, pagina = totalPaginas, itensPorPagina })">@totalPaginas</a></li>
                }
                <li class="page-item @(paginaAtual >= totalPaginas ? "disabled" : "")">
                    <a class="page-link" href="@(paginaAtual >= totalPaginas ? "#" : Url.Action("Index", new { estado = string.IsNullOrEmpty(estado) ? null : estado, pagina = paginaAtual + 1, itensPorPagina }))">Próximo</a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <p class="text-muted mb-2">Nenhuma encomenda encontrada.</p>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-primary">Nova encomenda</a>
            }
        </div>
    </div>
}

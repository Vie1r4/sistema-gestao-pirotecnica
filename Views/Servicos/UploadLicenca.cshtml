@model Finalproj.Models.ServicoLicenca
@using Finalproj.Models
@{
    ViewData["Title"] = "Upload licença";
    var servicoId = ViewData["ServicoId"] as int? ?? 0;
    var tipo = ViewData["TipoLicenca"] as int? ?? 0;
    var tipoNome = ViewData["TipoNome"] as string ?? "Licença";
    var isOutro = (TipoLicencaServico)tipo == TipoLicencaServico.OUTRO;
}
<h1 class="mb-3">@(Model.Id > 0 ? "Editar" : "Upload") — @tipoNome</h1>

<form asp-action="UploadLicenca" method="post" enctype="multipart/form-data">
    <input type="hidden" name="id" value="@servicoId" />
    <input type="hidden" name="tipo" value="@tipo" />
    <input type="hidden" name="licencaId" value="@(Model.Id > 0 ? Model.Id : (int?)null)" />
    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

    <div class="card mb-4">
        <div class="card-body">
            @if (isOutro)
            {
                <div class="mb-3">
                    <label class="form-label">Nome do documento</label>
                    <input name="NomePersonalizado" class="form-control" value="@Model.NomePersonalizado" placeholder="Ex: Autorização especial" maxlength="200" />
                </div>
            }
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">N.º documento</label>
                    <input name="NumeroDocumento" class="form-control" value="@Model.NumeroDocumento" placeholder="Ex: PSP/BRG/2026/045" maxlength="100" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Data emissão</label>
                    <input name="DataEmissao" class="form-control" type="date" value="@(Model.DataEmissao?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Data validade</label>
                    <input name="DataValidade" class="form-control" type="date" value="@(Model.DataValidade?.ToString("yyyy-MM-dd"))" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Observações</label>
                <textarea name="Observacoes" class="form-control" rows="2" maxlength="500">@Model.Observacoes</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Ficheiro (PDF, JPG ou PNG)</label>
                <input name="ficheiro" type="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                @if (!string.IsNullOrWhiteSpace(Model.FicheiroPath))
                {
                    <p class="small text-muted mt-1">Já existe um ficheiro carregado. Ao escolher um novo, substitui o anterior.</p>
                }
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Details" asp-route-id="@servicoId" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

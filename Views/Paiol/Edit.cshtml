@model Finalproj.Models.Paiol
@{
    ViewData["Title"] = "Editar Paiol";
}

<h1 class="mb-3">Editar paiol</h1>
<p class="text-muted mb-4">Altere os dados conforme necessário.</p>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    <input type="hidden" asp-for="Id" />

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Identificação e licença</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Nome" class="form-label"></label> <span class="text-danger">*</span>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Localizacao" class="form-label"></label>
                <input asp-for="Localizacao" class="form-control" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CoordenadasLat" class="form-label">Latitude</label>
                    <input asp-for="CoordenadasLat" class="form-control" type="number" step="0.000000001" placeholder="Ex: 41.5454" />
                    <small class="text-muted">Para "Ver rota do paiol" nos detalhes do serviço.</small>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CoordenadasLng" class="form-label">Longitude</label>
                    <input asp-for="CoordenadasLng" class="form-control" type="number" step="0.000000001" placeholder="Ex: -8.4265" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="LimiteMLE" class="form-label"></label> <span class="text-danger">*</span>
                    <input asp-for="LimiteMLE" class="form-control" type="number" step="any" min="0.01" />
                    <span asp-validation-for="LimiteMLE" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PerfilRisco" class="form-label"></label> <span class="text-danger">*</span>
                    <select asp-for="PerfilRisco" class="form-select" asp-items="@(ViewData["PerfisRisco"] as SelectList)">
                        <option value="">— Escolher —</option>
                    </select>
                    <span asp-validation-for="PerfilRisco" class="text-danger small"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Estado" class="form-label"></label> <span class="text-danger">*</span>
                    <select asp-for="Estado" class="form-select" asp-items="@(new SelectList(ViewData["Estados"] as string[] ?? Array.Empty<string>()))">
                        <option value="">— Escolher —</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="NumeroLicenca" class="form-label"></label>
                    <input asp-for="NumeroLicenca" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="DataValidadeLicenca" class="form-label"></label>
                <input asp-for="DataValidadeLicenca" class="form-control" type="date" />
            </div>
            <div class="mb-0">
                <label class="form-label">Cargos com acesso a este paiol</label>
                <p class="text-muted small mb-2">Altera quais os cargos que podem registar entrada neste paiol.</p>
                <div class="border rounded p-2 bg-light">
                    @{
                        var selecionados = ViewData["CargosSelecionados"] as IList<string> ?? new List<string>();
                    }
                    @foreach (var cargo in (ViewData["CargosDisponiveis"] as string[] ?? Array.Empty<string>()))
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="CargosAcesso" value="@cargo" id="cargo_@cargo"@(selecionados.Contains(cargo) ? " checked" : "") />
                            <label class="form-check-label" for="cargo_@cargo">@cargo</label>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Documentação</h5>
        </div>
        <div class="card-body">
            @if (Model.DocumentosExtras?.Any() == true)
            {
                <p class="small text-muted mb-2">Documentos já carregados (pode marcar para remover):</p>
                <ul class="list-unstyled mb-0">
                    @foreach (var ext in Model.DocumentosExtras)
                    {
                        <li class="mb-1 d-flex align-items-center gap-2">
                            <a asp-action="Download" asp-route-id="@Model.Id" asp-route-extraId="@ext.Id" target="_blank" class="btn btn-sm btn-outline-success">@(string.IsNullOrWhiteSpace(ext.Nome) ? "Ver" : ext.Nome)</a>
                            <label class="mb-0 small text-danger cursor-pointer">
                                <input type="checkbox" name="RemoverDocumentoExtraIds" value="@ext.Id" class="form-check-input" /> Remover
                            </label>
                        </li>
                    }
                </ul>
                <hr class="my-3" />
            }
            <p class="small text-muted mb-3">Adicionar mais documentos (nome à escolha). PDF, JPG ou PNG.</p>
            <div class="form-check d-flex align-items-center">
                <button type="button" id="btn-mais-documento" class="form-check-input documento-mais p-0 border-0 bg-transparent text-secondary d-flex align-items-center justify-content-center" style="width:1.15rem;height:1.15rem;margin-top:0.2rem;margin-right:0.5em;font-size:1rem;line-height:1;" aria-label="Adicionar documento">&#43;</button>
                <span class="form-check-label mb-0">Adicionar documento (nome à escolha)</span>
            </div>
            <div id="documentos-extras-container" class="mt-3 pt-2 border-top" style="display:none;">
                <p class="small fw-medium text-secondary mb-2">Novos documentos:</p>
                <div id="documentos-extras-lista"></div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <input type="submit" value="Guardar" class="btn btn-primary" />
        <a asp-action="Gestao" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function() {
            var containerExtras = document.getElementById('documentos-extras-container');
            var listaExtras = document.getElementById('documentos-extras-lista');
            var btnMais = document.getElementById('btn-mais-documento');
            var contadorExtras = 0;
            function renumerarExtras() {
                if (!listaExtras) return;
                var rows = listaExtras.querySelectorAll('.documento-extra-row');
                rows.forEach(function(r, idx) {
                    r.querySelector('input[name*=".Nome"]').setAttribute('name', 'documentosExtras[' + idx + '].Nome');
                    r.querySelector('input[type="file"]').setAttribute('name', 'documentosExtras[' + idx + '].Ficheiro');
                });
            }
            if (btnMais && listaExtras) {
                btnMais.addEventListener('click', function() {
                    if (!containerExtras) return;
                    containerExtras.style.display = 'block';
                    var i = contadorExtras++;
                    var row = document.createElement('div');
                    row.className = 'documento-extra-row mb-3 p-2 bg-light rounded';
                    row.innerHTML = '<div class="row g-2 align-items-end"><div class="col-md-4"><label class="form-label small mb-0">Nome do documento</label><input type="text" name="documentosExtras[' + i + '].Nome" class="form-control form-control-sm" placeholder="Ex: Licença, Planta..." maxlength="100" /></div><div class="col-md-5"><label class="form-label small mb-0">Ficheiro</label><input type="file" name="documentosExtras[' + i + '].Ficheiro" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png" /></div><div class="col-md-3"><button type="button" class="btn btn-outline-danger btn-sm remover-extra">Remover</button></div></div>';
                    listaExtras.appendChild(row);
                    row.querySelector('.remover-extra').addEventListener('click', function() { row.remove(); renumerarExtras(); if (listaExtras.children.length === 0) containerExtras.style.display = 'none'; });
                });
            }
        })();
    </script>
}

@model Finalproj.Models.Funcionario
@{
    ViewData["Title"] = "Desassociar conta";
}

<h1 class="mb-3">Desassociar conta</h1>
<p class="text-muted mb-4">Ao desassociar, a conta de acesso é removida e o utilizador <strong>deixa de poder entrar no site</strong>. A ficha do funcionário mantém-se; pode voltar a criar uma nova conta depois.</p>

<form asp-action="DesassociarConta" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-outline-danger">Desassociar conta e impedir acesso</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

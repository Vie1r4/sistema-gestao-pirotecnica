@model Finalproj.Models.Funcionario
@{
    ViewData["Title"] = "Detalhes do funcionário";
}

<h1 class="mb-2">@Model.NomeCompleto</h1>
<p class="text-muted mb-4">Ficha do funcionário</p>

@if (TempData["CredenciaisCriadas"] as bool? == true)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <strong>Conta criada.</strong> Foi enviado um email ao funcionário com as credenciais e um link para confirmar o email. Só após confirmar poderá entrar no site. Entregue se necessário: <strong>Email:</strong> @TempData["CredenciaisEmail"] | <strong>Palavra-passe:</strong> @TempData["CredenciaisPassword"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}
@if (TempData["ContaDesassociada"] as bool? == true)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        Conta desassociada. O utilizador já não pode entrar no site.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}
@if (TempData["DesassociarErro"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @TempData["DesassociarErro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Identificação e contacto</h5>
        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">Editar</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
            </div>
        }
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 col-md-2">Nome completo</dt>
            <dd class="col-sm-9 col-md-10">@Model.NomeCompleto</dd>
            <dt class="col-sm-3 col-md-2">NIF</dt>
            <dd class="col-sm-9 col-md-10">@(Model.NIF ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">Email</dt>
            <dd class="col-sm-9 col-md-10">@(Model.Email ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">Telefone</dt>
            <dd class="col-sm-9 col-md-10">@(Model.Telefone ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">Morada</dt>
            <dd class="col-sm-9 col-md-10">@(Model.Morada ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">N.º Segurança Social</dt>
            <dd class="col-sm-9 col-md-10">@(Model.NumeroSegurancaSocial ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">IBAN</dt>
            <dd class="col-sm-9 col-md-10">@(Model.IBAN ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">Cargo</dt>
            <dd class="col-sm-9 col-md-10">@(Model.Cargo ?? "—")</dd>
            @if (!string.IsNullOrWhiteSpace(Model.Notas))
            {
                <dt class="col-sm-3 col-md-2">Notas</dt>
                <dd class="col-sm-9 col-md-10">@Model.Notas</dd>
            }
            <dt class="col-sm-3 col-md-2">Conta de acesso</dt>
            <dd class="col-sm-9 col-md-10">
                @if (!string.IsNullOrEmpty(Model.UserId))
                {
                    var emailConfirmada = ViewData["ContaEmailConfirmada"] as bool? ?? false;
                    if (emailConfirmada)
                    {
                        <span class="badge bg-success">Sim</span>
                        <span class="text-muted small">(@(ViewData["ContaEmail"] ?? "—"))</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">À espera de confirmação</span>
                        <span class="text-muted small">(@(ViewData["ContaEmail"] ?? "—") — o funcionário deve clicar no link enviado por email para confirmar)</span>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="DesassociarConta" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger ms-2">Desassociar conta</a>
                    }
                }
                else
                {
                    <span class="badge bg-secondary">Não</span>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-2">Criar conta (editar funcionário)</a>
                    }
                }
            </dd>
            <dt class="col-sm-3 col-md-2">Data de registo</dt>
            <dd class="col-sm-9 col-md-10">@(Model.DataRegisto?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
        </dl>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">Documentos</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 col-md-2">Cartão de Cidadão</dt>
            <dd class="col-sm-9 col-md-10">
                @if (!string.IsNullOrEmpty(Model.CartaoCidadaoCaminho))
                {
                    <a asp-action="Download" asp-route-id="@Model.Id" asp-route-tipo="cc" target="_blank" class="btn btn-sm btn-outline-success">Ver documento</a>
                }
                else
                {
                    <span class="text-muted">—</span>
                }
            </dd>
            <dt class="col-sm-3 col-md-2">ADR</dt>
            <dd class="col-sm-9 col-md-10">
                @if (!string.IsNullOrEmpty(Model.DocumentoADDRCaminho))
                {
                    <a asp-action="Download" asp-route-id="@Model.Id" asp-route-tipo="addr" target="_blank" class="btn btn-sm btn-outline-success">Ver documento</a>
                }
                else
                {
                    <span class="text-muted">—</span>
                }
            </dd>
            <dt class="col-sm-3 col-md-2">Licença de Operador</dt>
            <dd class="col-sm-9 col-md-10">
                @if (!string.IsNullOrEmpty(Model.LicencaOperadorCaminho))
                {
                    <a asp-action="Download" asp-route-id="@Model.Id" asp-route-tipo="licenca" target="_blank" class="btn btn-sm btn-outline-success">Ver documento</a>
                }
                else
                {
                    <span class="text-muted">—</span>
                }
            </dd>
            @if (Model.DocumentosExtras?.Any() == true || !string.IsNullOrEmpty(Model.OutrosCaminho))
            {
                <dt class="col-sm-3 col-md-2">Documentos adicionais</dt>
                <dd class="col-sm-9 col-md-10">
                    @if (Model.DocumentosExtras?.Any() == true)
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var ext in Model.DocumentosExtras)
                            {
                                <li class="mb-1">
                                    <a asp-action="Download" asp-route-id="@Model.Id" asp-route-tipo="extra" asp-route-extraId="@ext.Id" target="_blank" class="btn btn-sm btn-outline-success">@(string.IsNullOrWhiteSpace(ext.Nome) ? "Ver documento" : ext.Nome)</a>
                                </li>
                            }
                        </ul>
                    }
                    @if (!string.IsNullOrEmpty(Model.OutrosCaminho))
                    {
                        <p class="mb-0 mt-1"><a asp-action="Download" asp-route-id="@Model.Id" asp-route-tipo="outros" target="_blank" class="btn btn-sm btn-outline-secondary">Outros (antigo)</a></p>
                    }
                </dd>
            }
        </dl>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar à lista</a>
</div>

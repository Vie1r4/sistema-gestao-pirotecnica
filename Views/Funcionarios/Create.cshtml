@model Finalproj.Models.Funcionario
@{
    ViewData["Title"] = "Adicionar funcionário";
}

<h1 class="mb-3">Adicionar funcionário</h1>
<p class="text-muted mb-4">Preencha os dados do colaborador. Os campos marcados com <span class="text-danger">*</span> são obrigatórios.</p>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Identificação e contacto</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="NomeCompleto" class="form-label"></label> <span class="text-danger">*</span>
                <input asp-for="NomeCompleto" class="form-control" placeholder="Nome completo" />
                <span asp-validation-for="NomeCompleto" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NIF" class="form-label"></label>
                    <input asp-for="NIF" class="form-control" maxlength="9" placeholder="9 dígitos" />
                    <span asp-validation-for="NIF" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="exemplo@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Telefone" class="form-label"></label>
                    <input asp-for="Telefone" class="form-control" placeholder="Telefone" />
                    <span asp-validation-for="Telefone" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Morada" class="form-label"></label>
                    <input asp-for="Morada" class="form-control" placeholder="Morada" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NumeroSegurancaSocial" class="form-label"></label>
                    <input asp-for="NumeroSegurancaSocial" class="form-control" placeholder="N.º Segurança Social" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="IBAN" class="form-label"></label>
                    <input asp-for="IBAN" class="form-control" placeholder="IBAN" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Cargo" class="form-label"></label>
                    <select asp-for="Cargo" class="form-select" asp-items="@ViewBag.Cargo">
                        <option value="">— Selecionar —</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Notas" class="form-label"></label> <span class="text-muted small">(opcional)</span>
                    <textarea asp-for="Notas" class="form-control" rows="1" placeholder="Notas"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Documentos</h5>
        </div>
        <div class="card-body">
            <p class="small text-muted mb-3">Selecione os documentos que pretende submeter. Abaixo aparecerá o campo para escolher o ficheiro. PDF, JPG ou PNG.</p>
            <div class="mb-3">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input documento-selecionar" id="sel_cc" data-doc="cc" style="width:1.15rem;height:1.15rem;margin-top:0.2rem;">
                    <label class="form-check-label" for="sel_cc">Cartão de Cidadão</label>
                </div>
                <div class="form-check">
                    <input type="checkbox" class="form-check-input documento-selecionar" id="sel_addr" data-doc="addr" style="width:1.15rem;height:1.15rem;margin-top:0.2rem;">
                    <label class="form-check-label" for="sel_addr">ADR</label>
                </div>
                <div class="form-check">
                    <input type="checkbox" class="form-check-input documento-selecionar" id="sel_licenca" data-doc="licenca" style="width:1.15rem;height:1.15rem;margin-top:0.2rem;">
                    <label class="form-check-label" for="sel_licenca">Licença de Operador</label>
                </div>
                <div class="form-check d-flex align-items-center">
                    <button type="button" id="btn-mais-documento" class="form-check-input documento-mais p-0 border-0 bg-transparent text-secondary d-flex align-items-center justify-content-center" style="width:1.15rem;height:1.15rem;margin-top:0.2rem;margin-right:0.5em;font-size:1rem;line-height:1;" aria-label="Adicionar documento">&#43;</button>
                    <span class="form-check-label mb-0">Adicionar documento (nome à escolha)</span>
                </div>
            </div>
            <div id="bloco-ficheiros" class="mt-3 pt-3 border-top" style="display:none;">
                <p class="small fw-medium text-secondary mb-2">Selecionar ficheiro(s):</p>
                <div id="ficheiro_cc" class="mb-2" style="display:none;">
                    <label class="form-label small mb-0">Cartão de Cidadão</label>
                    <input type="file" name="cartaoCidadaoFicheiro" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png" />
                </div>
                <div id="ficheiro_addr" class="mb-2" style="display:none;">
                    <label class="form-label small mb-0">ADR</label>
                    <input type="file" name="documentoADDRFicheiro" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png" />
                </div>
                <div id="ficheiro_licenca" class="mb-2" style="display:none;">
                    <label class="form-label small mb-0">Licença de Operador</label>
                    <input type="file" name="licencaOperadorFicheiro" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png" />
                </div>
                <div id="documentos-extras-container" class="mt-3 pt-2 border-top" style="display:none;">
                    <p class="small fw-medium text-secondary mb-2">Documentos adicionais (indique o nome e escolha o ficheiro):</p>
                    <div id="documentos-extras-lista"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Conta de acesso ao sistema</h5>
        </div>
        <div class="card-body">
            <p class="small text-muted mb-3">Opcionalmente pode criar uma conta para este funcionário poder entrar no sistema. Depois entregue-lhe o email e a palavra-passe.</p>
            <div class="form-check mb-3">
                <input type="checkbox" class="form-check-input" name="criarConta" value="true" id="criarConta" style="width:1.15rem;height:1.15rem;margin-top:0.2rem;">
                <label class="form-check-label" for="criarConta">Criar conta de acesso para este funcionário</label>
            </div>
            <div id="bloco-conta-create" style="display:none;">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="contaEmail">Email para login</label>
                        <input type="email" name="contaEmail" id="contaEmail" class="form-control" placeholder="exemplo@email.com" value="@Model.Email" />
                        <span class="text-danger small" data-valmsg-for="ContaEmail" data-valmsg-replace="true"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="contaRole">Perfil de acesso</label>
                        <select name="contaRole" id="contaRole" class="form-select" asp-items="@ViewBag.RolesConta">
                            <option value="">— Selecionar —</option>
                        </select>
                        <span class="text-danger small" data-valmsg-for="ContaRole" data-valmsg-replace="true"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="contaPassword">Palavra-passe</label>
                        <input type="password" name="contaPassword" id="contaPassword" class="form-control" autocomplete="new-password" />
                        <p class="form-text small text-muted mb-0">Mín. 6 caracteres, com pelo menos uma maiúscula, uma minúscula e um algarismo.</p>
                        <span class="text-danger small" data-valmsg-for="ContaPassword" data-valmsg-replace="true"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="contaConfirmPassword">Confirmar palavra-passe</label>
                        <input type="password" name="contaConfirmPassword" id="contaConfirmPassword" class="form-control" />
                        <span class="text-danger small" data-valmsg-for="ContaConfirmPassword" data-valmsg-replace="true"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function() {
            var blocoFicheiros = document.getElementById('bloco-ficheiros');
            var containerExtras = document.getElementById('documentos-extras-container');
            var listaExtras = document.getElementById('documentos-extras-lista');
            var btnMais = document.getElementById('btn-mais-documento');
            var contadorExtras = 0;

            function atualizarVisibilidadeBloco() {
                var algumCheck = document.querySelector('.documento-selecionar:checked');
                var algumExtra = listaExtras && listaExtras.children.length > 0;
            if (blocoFicheiros) blocoFicheiros.style.display = (algumCheck || algumExtra) ? 'block' : 'none';
        }
        var criarContaCb = document.getElementById('criarConta');
        var blocoConta = document.getElementById('bloco-conta-create');
        if (criarContaCb && blocoConta) {
            criarContaCb.addEventListener('change', function() { blocoConta.style.display = this.checked ? 'block' : 'none'; });
        }
            function renumerarExtras() {
                if (!listaExtras) return;
                var rows = listaExtras.querySelectorAll('.documento-extra-row');
                rows.forEach(function(r, idx) {
                    r.querySelector('input[name*=".Nome"]').setAttribute('name', 'DocumentosExtras[' + idx + '].Nome');
                    r.querySelector('input[type="file"]').setAttribute('name', 'DocumentosExtras[' + idx + '].Ficheiro');
                });
            }

            document.querySelectorAll('.documento-selecionar').forEach(function(cb) {
                cb.addEventListener('change', function() {
                    var doc = this.getAttribute('data-doc');
                    var div = doc ? document.getElementById('ficheiro_' + doc) : null;
                    if (div) div.style.display = this.checked ? 'block' : 'none';
                    atualizarVisibilidadeBloco();
                });
            });

            if (btnMais && listaExtras) {
                btnMais.addEventListener('click', function() {
                    if (!containerExtras) return;
                    containerExtras.style.display = 'block';
                    var i = contadorExtras++;
                    var row = document.createElement('div');
                    row.className = 'documento-extra-row mb-3 p-2 bg-light rounded';
                    row.innerHTML =
                        '<div class="row g-2 align-items-end">' +
                        '  <div class="col-md-4"><label class="form-label small mb-0">Nome do documento</label><input type="text" name="DocumentosExtras[' + i + '].Nome" class="form-control form-control-sm" placeholder="Ex: Certificado, Contrato..." maxlength="100" /></div>' +
                        '  <div class="col-md-5"><label class="form-label small mb-0">Ficheiro</label><input type="file" name="DocumentosExtras[' + i + '].Ficheiro" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png" /></div>' +
                        '  <div class="col-md-3"><button type="button" class="btn btn-outline-danger btn-sm remover-extra">Remover</button></div>' +
                        '</div>';
                    listaExtras.appendChild(row);
                    row.querySelector('.remover-extra').addEventListener('click', function() {
                        row.remove();
                        renumerarExtras();
                        if (listaExtras.children.length === 0) containerExtras.style.display = 'none';
                        atualizarVisibilidadeBloco();
                    });
                    atualizarVisibilidadeBloco();
                });
            }
        })();
    </script>
}

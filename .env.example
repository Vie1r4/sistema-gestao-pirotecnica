# Variáveis de ambiente para produção (exemplo).
# No ASP.NET Core, use o separador __ em vez de : (ex.: Jwt__Secret).
# Em desenvolvimento, prefira dotnet user-secrets — ver README.md.

# Obrigatório em Production
# Jwt__Secret=
# Jwt__Issuer=Finalproj
# Jwt__Audience=FinalprojUsers
# Cors__AllowedOrigins__0=https://app.seudominio.pt
# ConnectionStrings__FinalprojContext=Server=...;Database=...;User Id=...;Password=...;
# Bootstrap__AllowFirstUserRegistration=false

# Frontend (ficheiro separado em apps/web/.env.example)
# NEXT_PUBLIC_API_URL=https://api.seudominio.pt

# Opcional — email (reset de palavra-passe, confirmação de conta)
# Email__SmtpHost=
# Email__SmtpUser=
# Email__SmtpPassword=
# Email__From=
# Frontend__BaseUrl=https://app.seudominio.pt
